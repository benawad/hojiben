---
import Layout from '../layouts/Layout.astro';
import MapPlate from '../components/MapPlate.astro';
import Leaderboard from '../components/Leaderboard.astro';
import { getRankedSpots, isLocal } from '../lib/spots';
import { leaderboardSchema } from '../lib/schema';
import { SITE, AUTHOR } from '../data/site';

const spots = await getRankedSpots();
// Leaderboard is SF-only for now; out-of-town spots still have detail pages.
const sfSpots = spots.filter(isLocal);
---

<Layout
  title="Best Hojicha in San Francisco, Ranked"
  description={SITE.description}
  path="/"
  crumb="index"
  ogImage="/og/home.png"
  jsonLd={leaderboardSchema(sfSpots)}
>
  <div class="body">
    <section class="col-main">
      <h1 class="h1">Best hojicha in San Francisco</h1>
      <p class="intro">
        A running list of every hojicha I've tried, ranked best to worst.
      </p>

      <div class="panel">
        <div class="panel-head">
          <span class="mono">the_index · {sfSpots.length} spots</span>
          <span class="mono muted">best → worst</span>
        </div>
        <Leaderboard spots={sfSpots} />
      </div>
    </section>

    <aside class="col-side">
      <div class="panel">
        <div class="panel-head">
          <span class="mono">sf.map</span>
          <span class="mono muted">{sfSpots.length} plotted</span>
        </div>
        <div class="panel-pad">
          <MapPlate spots={sfSpots} />
        </div>
      </div>

      <div class="panel">
        <div class="panel-head">
          <span class="mono">readme</span>
        </div>
        <div class="panel-pad readme">
          <div class="who">
            <img src={AUTHOR.avatar} alt={AUTHOR.name} width="34" height="34" />
            <div>
              <p class="who-name">{AUTHOR.name}</p>
              <p class="who-handle mono muted">{AUTHOR.handle}</p>
            </div>
          </div>
          <p class="who-bio">{AUTHOR.bio}</p>
          <a class="more mono" href="/about">about → </a>
        </div>
      </div>
    </aside>
  </div>
</Layout>

<style>
  .body {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-5);
    padding: var(--space-5);
  }
  .h1 {
    margin: 0 0 var(--space-2);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .intro {
    margin: 0 0 var(--space-4);
    max-width: 56ch;
    color: var(--ink-soft);
    font-size: 0.86rem;
  }

  .panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--window);
    overflow: hidden;
  }
  .panel + .panel {
    margin-top: var(--space-4);
  }
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px var(--space-3);
    background: var(--panel);
    border-bottom: 1px solid var(--line);
    font-size: 0.7rem;
  }
  .panel-pad {
    padding: var(--space-3);
  }

  .readme .who {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .readme img {
    width: 34px;
    height: 34px;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }
  .who-name {
    margin: 0;
    font-weight: 600;
    font-size: 0.82rem;
  }
  .who-handle {
    margin: 0;
    font-size: 0.66rem;
  }
  .who-bio {
    margin: var(--space-3) 0;
    color: var(--ink-soft);
    font-size: 0.8rem;
  }
  .more {
    font-size: 0.72rem;
    color: var(--ink);
    border-bottom: 1px solid var(--line-strong);
    padding-bottom: 1px;
  }
  .more:hover {
    border-color: var(--ink);
  }

  @media (max-width: 880px) {
    .body {
      grid-template-columns: 1fr;
    }
  }
</style>
