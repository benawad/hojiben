---
const title = "Hojiben";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Hojiben is live on Cloudflare Pages." />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <p class="eyebrow">hojiben.com</p>
      <h1>Hello World</h1>
      <p>Hojiben is live.</p>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: #f7f7f2;
    color: #141414;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  main {
    width: min(640px, calc(100vw - 40px));
  }

  .eyebrow {
    margin: 0 0 16px;
    color: #63635c;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  p {
    margin: 20px 0 0;
    color: #3c3c36;
    font-size: 1.125rem;
  }
</style>
