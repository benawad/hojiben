---
import Layout from '../layouts/Layout.astro';
import MapPlate from '../components/MapPlate.astro';
import Leaderboard from '../components/Leaderboard.astro';
import { getRankedDrinkSpots, getSpecialItems, drinkShort, hasCoordinates, isLocal } from '../lib/spots';
import { leaderboardSchema } from '../lib/schema';
import { SITE, AUTHOR } from '../data/site';

const spots = await getRankedDrinkSpots();
const specialItems = (await getSpecialItems()).filter(isLocal);
// Leaderboard is SF-only for now; out-of-town spots still have detail pages.
const sfSpots = spots.filter(isLocal);
const mappedSpots = sfSpots.filter(hasCoordinates);
---

<Layout
  title="Best Hojicha in San Francisco, Ranked"
  description={SITE.description}
  path="/"
  crumb="index"
  ogImage="/og/home.png"
  jsonLd={leaderboardSchema(sfSpots)}
>
  <div class="body">
    <section class="col-main">
      <h1 class="h1">Best hojicha in San Francisco</h1>
      <p class="intro">
        A running list of every hojicha I've tried, ranked best to worst.
      </p>

      <div class="panel">
        <div class="panel-head">
          <span class="mono">the_index · {sfSpots.length} spots</span>
          <span class="mono muted">best → worst</span>
        </div>
        <Leaderboard spots={sfSpots} />
      </div>

      {
        specialItems.length > 0 && (
          <div class="panel">
            <div class="panel-head">
              <span class="mono">special_items · {specialItems.length}</span>
              <span class="mono muted">not ranked</span>
            </div>
            <div class="special-list">
              {specialItems.map((spot) => (
                <a class="special-row" href={`/spots/${spot.id}/`}>
                  <span class="special-main">
                    <span class="special-name">{spot.data.name}</span>
                    <span class="special-meta mono muted">
                      {drinkShort(spot.data.drink).toLowerCase()} · {spot.data.neighborhood.toLowerCase()}
                    </span>
                  </span>
                  <span class="score mono">{spot.data.grade ?? '—'}</span>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </section>

    <aside class="col-side">
      <div class="panel">
        <div class="panel-head">
          <span class="mono">sf.map</span>
          <span class="mono muted">{mappedSpots.length} plotted</span>
        </div>
        <div class="panel-pad">
          <MapPlate spots={sfSpots} />
        </div>
      </div>

      <div class="panel">
        <div class="panel-head">
          <span class="mono">readme</span>
        </div>
        <div class="panel-pad readme">
          <div class="who">
            <img src={AUTHOR.avatar} alt={AUTHOR.name} width="34" height="34" />
            <div>
              <p class="who-name">{AUTHOR.name}</p>
              <p class="who-handle mono muted">{AUTHOR.handle}</p>
            </div>
          </div>
          <p class="who-bio">{AUTHOR.bio}</p>
        </div>
      </div>
    </aside>
  </div>
</Layout>

<style>
  .body {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-5);
    padding: var(--space-5);
  }
  .h1 {
    margin: 0 0 var(--space-2);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .intro {
    margin: 0 0 var(--space-4);
    max-width: 56ch;
    color: var(--ink-soft);
    font-size: 0.86rem;
  }

  .panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--window);
    overflow: hidden;
  }
  .panel + .panel {
    margin-top: var(--space-4);
  }
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px var(--space-3);
    background: var(--panel);
    border-bottom: 1px solid var(--line);
    font-size: 0.7rem;
  }
  .panel-pad {
    padding: var(--space-3);
  }
  .special-list {
    display: grid;
  }
  .special-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: 8px var(--space-3);
    color: var(--ink);
  }
  .special-row:hover {
    background: var(--hover);
  }
  .special-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .special-name {
    font-weight: 600;
    font-size: 0.84rem;
  }
  .special-meta {
    font-size: 0.66rem;
  }
  .score {
    font-size: 0.84rem;
    font-weight: 500;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .readme .who {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .readme img {
    width: 34px;
    height: 34px;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }
  .who-name {
    margin: 0;
    font-weight: 600;
    font-size: 0.82rem;
  }
  .who-handle {
    margin: 0;
    font-size: 0.66rem;
  }
  .who-bio {
    margin: var(--space-3) 0 0;
    color: var(--ink-soft);
    font-size: 0.8rem;
  }

  @media (max-width: 880px) {
    .body {
      grid-template-columns: 1fr;
    }
  }
</style>
