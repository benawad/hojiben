---
import Layout from '../layouts/Layout.astro';
import { getRankedDrinkSpots, isLocal, TIERS } from '../lib/spots';
import { leaderboardSchema, breadcrumbSchema } from '../lib/schema';

const spots = await getRankedDrinkSpots();

const rows = TIERS.map((t) => ({
  tier: t.tier,
  spots: spots.filter((s) => s.data.grade && t.grades.includes(s.data.grade)),
}));
const ungraded = spots.filter((s) => !s.data.grade);

// Monochrome ramp — S darkest → F lightest.
const SHADE: Record<string, { bg: string; fg: string }> = {
  S: { bg: '#1d1d1f', fg: '#ffffff' },
  A: { bg: '#3a3a3d', fg: '#ffffff' },
  B: { bg: '#5c5c61', fg: '#ffffff' },
  C: { bg: '#8a8a90', fg: '#ffffff' },
  D: { bg: '#b4b4ba', fg: '#1d1d1f' },
  F: { bg: '#d6d6da', fg: '#1d1d1f' },
};
---

<Layout
  title="Hojicha Tier List: San Francisco"
  description="Every San Francisco hojicha Hoji Ben has tried, sorted into a tier list from S down to F."
  path="/tierlist/"
  crumb="tierlist"
  jsonLd={[
    leaderboardSchema(spots),
    breadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'Tier List', path: '/tierlist' },
    ]),
  ]}
>
  <div class="head">
    <span class="title mono">tierlist</span>
    <span class="head-meta mono muted">{spots.length} spots · S → F</span>
  </div>

  <div class="pad">
    <p class="intro">
      The same rankings as the index, stacked into tiers. S is the dream; F is a
      warning.
    </p>

    <div class="tiers">
      {
        rows.map((row) => (
          <div class="row">
            <div class="tier" style={`background:${SHADE[row.tier].bg}; color:${SHADE[row.tier].fg}`}>
              {row.tier}
            </div>
            <div class="band">
              {row.spots.length === 0 ? (
                <span class="empty mono muted">—</span>
              ) : (
                row.spots.map((s) => (
                  <a class="chip" href={`/spots/${s.id}/`} data-oot={!isLocal(s) ? 'true' : undefined}>
                    <span class="chip-name">{s.data.name}</span>
                    {!isLocal(s) && <span class="chip-oot mono">out of town</span>}
                    <span class="chip-grade mono">{s.data.grade}</span>
                  </a>
                ))
              )}
            </div>
          </div>
        ))
      }

      {
        ungraded.length > 0 && (
          <div class="row">
            <div class="tier tier-q">?</div>
            <div class="band">
              {ungraded.map((s) => (
                <a class="chip" href={`/spots/${s.id}/`}>
                  <span class="chip-name">{s.data.name}</span>
                  <span class="chip-grade mono muted">ungraded</span>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>
</Layout>

<style>
  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--line);
    background: var(--panel);
  }
  .title {
    font-size: 0.78rem;
  }
  .head-meta {
    font-size: 0.7rem;
  }
  .pad {
    padding: var(--space-5);
  }
  .intro {
    margin: 0 0 var(--space-4);
    color: var(--ink-soft);
    font-size: 0.86rem;
    max-width: 56ch;
  }

  .tiers {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .row {
    display: grid;
    grid-template-columns: 52px 1fr;
    border-bottom: 1px solid var(--line);
  }
  .row:last-child {
    border-bottom: 0;
  }
  .tier {
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }
  .tier-q {
    background: var(--panel);
    color: var(--ink-faint);
    border-right: 1px solid var(--line);
  }
  .band {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    padding: var(--space-2) var(--space-3);
    min-height: 46px;
    background: var(--window);
  }
  .empty {
    font-size: 0.8rem;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 5px 9px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-sm);
    background: var(--panel);
    color: var(--ink);
    transition: background 0.12s ease, border-color 0.12s ease;
  }
  .chip:hover {
    background: var(--hover);
    border-color: var(--ink-muted);
  }
  .chip-name {
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .chip-grade {
    font-size: 0.66rem;
    color: var(--ink-muted);
  }
  .chip[data-oot] {
    border-style: dashed;
  }
  .chip-oot {
    font-size: 0.54rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-muted);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0 5px;
  }
</style>
