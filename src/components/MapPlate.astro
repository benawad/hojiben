---
import { drinkLabel, isLocal, type Spot } from '../lib/spots';

interface Props {
  spots: Spot[];
}
const { spots } = Astro.props;

// SF bounding box (north-up); pins placed from real lat/lng over /sf-map.jpg.
const W = -122.516;
const E = -122.354;
const N = 37.814;
const S = 37.708;
const clamp = (n: number) => Math.max(3, Math.min(97, n));
// Keep the leaderboard rank, but only plot San Francisco spots.
const placed = spots
  .map((spot, i) => ({
    spot,
    rank: i + 1,
    x: clamp(((spot.data.lng - W) / (E - W)) * 100),
    y: clamp(((N - spot.data.lat) / (N - S)) * 100),
  }))
  .filter((p) => isLocal(p.spot));
---

<div class="map">
  <div class="img" role="img" aria-label="Map of San Francisco showing hojicha cafes ranked by Hoji Ben">
    <ul class="pins">
      {
        placed.map(({ spot, rank, x, y }) => (
          <li class="pin" data-top={rank <= 3 ? 'true' : undefined} style={`left:${x}%; top:${y}%`}>
            <a href={`/spots/${spot.id}`}>
              <span class="dot" />
              <span class="tip mono">
                {String(rank).padStart(2, '0')} · {spot.data.name}{spot.data.grade ? ` · ${spot.data.grade}` : ''}
              </span>
              <span class="visually-hidden">
                {`#${rank} ${spot.data.name}, ${drinkLabel(spot.data.drink)}${spot.data.grade ? `, graded ${spot.data.grade}` : ''}`}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  .map {
    width: 100%;
  }
  .img {
    position: relative;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background-color: #f1f1f3;
    background-image:
      url('/sf-map.jpg'),
      repeating-linear-gradient(0deg, transparent 0 23px, var(--line) 23px 24px),
      repeating-linear-gradient(90deg, transparent 0 23px, var(--line) 23px 24px);
    background-size: cover, auto, auto;
    background-position: center;
    background-repeat: no-repeat, repeat, repeat;
    filter: grayscale(1) contrast(1.03);
    overflow: hidden;
  }
  .pins {
    position: absolute;
    inset: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pin {
    position: absolute;
    transform: translate(-50%, -50%);
  }
  .pin > a {
    display: block;
    position: relative;
  }
  .dot {
    display: block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--window);
    border: 2px solid var(--ink);
    box-shadow: 0 0 0 2.5px rgba(255, 255, 255, 0.8);
    transition: transform 0.14s ease;
  }
  .pin[data-top] .dot {
    background: var(--ink);
  }
  .pin > a:hover .dot {
    transform: scale(1.4);
  }
  .tip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    background: var(--ink);
    color: #fff;
    font-size: 0.64rem;
    padding: 3px 6px;
    border-radius: var(--radius-sm);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.12s ease;
    z-index: 3;
  }
  .pin > a:hover .tip {
    opacity: 1;
  }
</style>
